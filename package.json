{
  "name": "makeuse-marketplace",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/makeuse-admin",
    "apps/api",
    "apps/ai-pricing",
    "apps/mobile",
    "packages/*"
  ],
  "dependencies": {
    "@prisma/client": "^7.4.2",
    "prisma": "^7.4.2",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "scripts": {
    "postinstall": "npm run generate --workspace=database",
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspaces --parallel",
    "seed": "npm run seed --workspace=database"
  },
  "overrides": {
    "next": "15.1.6",
    "tailwindcss": "3.4.1",
    "eslint-config-next": "15.1.6",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  }
}
